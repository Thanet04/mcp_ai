        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"deepseek/deepseek-chat\",\n  \"max_tokens\": 1000,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"คุณคือผู้เชี่ยวชาญด้านการวิเคราะห์การตลาดระดับ senior วิเคราะห์ธุรกิจอย่างลึกซึ้งและเป็นมืออาชีพ\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"ช่วยวิเคราะห์ธุรกิจด้านล่างนี้เป็นภาษาไทย\\n\\n{{$json.text}}\\n\\nให้ระบุชื่อแบรนด์จากเนื้อหา (ถ้ามี) หากไม่มีให้ใส่ \\\"unknown\\\"\\n\\nกรุณาตอบกลับเป็น JSON เท่านั้น ห้ามมีข้อความอื่น\\n\\nรูปแบบต้องเป็นแบบนี้เท่านั้น:\\n{\\n  \\\"brand_name\\\": \\\"ชื่อแบรนด์\\\",\\n  \\\"industry\\\": \\\"อุตสาหกรรมของธุรกิจ\\\",\\n  \\\"target_audience\\\": \\\"กลุ่มเป้าหมาย\\\",\\n  \\\"tone\\\": \\\"โทนการสื่อสาร\\\",\\n  \\\"reason\\\": \\\"เหตุผลที่วิเคราะห์\\\"\\n  \\\"keywords\\\": [\\\"คีย์เวิร์ด1\\\", \\\"คีย์เวิร์ด2\\\"],\\n}\"\n    }\n  ]\n}",
        "options": {}
      },
