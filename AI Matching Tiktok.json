    {
      "parameters": {
        "jsCode": "let raw = $input.first().json.choices[0].message.content;\n\n// ลบ ```json และ ```\nraw = raw.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\ntry {\n  const parsed = JSON.parse(raw);\n  return [parsed];\n} catch (e) {\n  return [{\n    error: \"Parse failed\",\n    raw: raw\n  }];\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1360,
        0
      ],
      "id": "a9118213-5d1a-48c4-830d-4f3832fcf14b",
      "name": "analyze brand"
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  let content = item.json.choices?.[0]?.message?.content || \"\";\n\n  // ลบ code block ทุกแบบ\n  content = content\n    .replace(/```json/g, \"\")\n    .replace(/```/g, \"\")\n    .replace(/^\\s*json\\s*/i, \"\")\n    .trim();\n\n  // ดึงเฉพาะ JSON object (กัน text หลุด)\n  const match = content.match(/\\{[\\s\\S]*\\}/);\n\n  if (!match) {\n    return {\n      json: {\n        error: \"No valid JSON found\",\n        raw: content\n      }\n    };\n  }\n\n  try {\n    return {\n      json: JSON.parse(match[0])\n    };\n  } catch (e) {\n    return {\n      json: {\n        error: \"JSON parse failed\",\n        raw: content,\n        message: e.message\n      }\n    };\n  }\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3104,
        0
      ],
      "id": "7c95d63a-bb73-429f-82a0-6b04ab59b061",
